{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "DenyIamUserCreation",
      "Effect": "Deny",
      "Action": [
        "iam:CreateUser",
        "iam:CreateAccessKey",
        "iam:CreateLoginProfile",
        "iam:AttachUserPolicy",
        "iam:PutUserPolicy",
        "iam:AddUserToGroup",
        "iam:UpdateLoginProfile"
      ],
      "Resource": "*"
    }
  ]
}
