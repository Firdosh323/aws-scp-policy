{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "RestrictEc2InstanceTypes",
      "Effect": "Deny",
      "Action": "ec2:RunInstances",
      "Resource": "*",
      "Condition": {
        "StringNotLike": {
          "ec2:InstanceType": [
            "t3.*",
            "t4g.*",
            "m6i.*",
            "c6i.*"
          ]
        }
      }
    }
  ]
}
